# Copy to .env.deploy (gitignored) and fill in values.
# Used by bin/deploy.sh.

# --- Required ---

# Dockhand API Bearer token (from Dockhand UI → Settings → API tokens).
DOCKHAND_TOKEN=dh_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Password for the shared db-mysql container on the VPS. Stored as a dockhand
# secret on the funniedev-website stack.
FUNNIE_DB_PASSWORD=change-me

# Admin user created on the first deploy. Used again on redeploy only if
# WordPress core is not yet installed.
WP_ADMIN_USER=admin
WP_ADMIN_PASS=change-me
WP_ADMIN_EMAIL=you@example.com

# --- Optional overrides ---

# VPS_HOST=root@quailman.lan
# VPS_PORT=8088
# VPS_SITE_DIR=/root/apps/sites/funnie.dev
# SITE_URL=https://funnie.dev
# DOCKHAND_URL=http://localhost:3000
# DOCKHAND_ENV=1
# STACK_NAME=funniedev-website
# COMPOSE_FILE=deploy/funnie-stack.yml
